<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <PlatformTarget>x86</PlatformTarget>
    <LangVersion>7.3</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="3.6.3" />
    <PackageReference Include="MSTest.TestFramework" Version="3.6.3" />
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- 本体は事前に msbuild EyeCenter.sln /p:Configuration=Debug /p:Platform=x86 でビルドしておくこと -->
    <Reference Include="EyeCenter">
      <HintPath>..\bin\x86\Debug\EyeCenter.exe</HintPath>
    </Reference>
    <Reference Include="System.Drawing" />
  </ItemGroup>

  <ItemGroup>
    <!-- EyeCenter.exe の依存DLL（MedicalLibrary, Interop.Excel など）をテスト実行フォルダへコピー -->
    <None Include="..\bin\x86\Debug\*.dll" CopyToOutputDirectory="PreserveNewest" Link="%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
